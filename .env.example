# Autonomyx Model Gateway — Environment Variables
# Copy to .env and fill in all YOUR_* values before running.
# Generate random secrets with: openssl rand -hex 32

# ── Gateway ───────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-autonomyx-YOUR_MASTER_KEY        # generate: openssl rand -hex 16
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=YOUR_LITELLM_UI_PASSWORD

# ── Postgres (LiteLLM spend logs) ─────────────────────────────────────────────
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
DATABASE_URL=postgresql://litellm:${POSTGRES_PASSWORD}@litellm-db:5432/litellm

# ── Cloud LLM APIs (fallback only — add keys for providers you have) ──────────
# At minimum, add GROQ_API_KEY — it's free tier, fastest fallback
GROQ_API_KEY=YOUR_GROQ_API_KEY                # free at console.groq.com
OPENAI_API_KEY=                               # platform.openai.com
ANTHROPIC_API_KEY=                            # console.anthropic.com
GEMINI_API_KEY=                               # aistudio.google.com
MISTRAL_API_KEY=                              # console.mistral.ai
TOGETHER_API_KEY=                             # api.together.xyz
FIREWORKS_API_KEY=                            # fireworks.ai
OPENROUTER_API_KEY=                           # openrouter.ai
AZURE_API_KEY=
AZURE_API_BASE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
HF_TOKEN=                                     # huggingface.co/settings/tokens

# ── Lago (billing) ────────────────────────────────────────────────────────────
LAGO_DB_PASSWORD=YOUR_LAGO_DB_PASSWORD
LAGO_SECRET_KEY_BASE=YOUR_64_CHAR_SECRET      # openssl rand -hex 32
LAGO_ENCRYPTION_PRIMARY_KEY=YOUR_32_CHAR_KEY  # openssl rand -hex 16
LAGO_ENCRYPTION_DETERMINISTIC_KEY=YOUR_32_CHAR_KEY
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=YOUR_32_CHAR_KEY
LAGO_API_URL=https://billing.openautonomyx.com
LAGO_FRONT_URL=https://billing-ui.openautonomyx.com
LAGO_API_KEY=YOUR_LAGO_API_KEY                # from Lago UI after setup

# ── Keycloak (auth) ───────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=YOUR_KEYCLOAK_ADMIN_PASSWORD
KEYCLOAK_DB_PASSWORD=YOUR_KEYCLOAK_DB_PASSWORD
KEYCLOAK_URL=https://auth.openautonomyx.com

# ── Langfuse (tracing) ────────────────────────────────────────────────────────
LANGFUSE_NEXTAUTH_SECRET=YOUR_32_CHAR_SECRET  # openssl rand -hex 32
LANGFUSE_DB_PASSWORD=YOUR_LANGFUSE_DB_PASSWORD
LANGFUSE_SALT=YOUR_SALT                       # openssl rand -hex 16
# Langfuse project keys (from Langfuse UI after setup)
LANGFUSE_PUBLIC_KEY=pk-lf-YOUR_KEY
LANGFUSE_SECRET_KEY=sk-lf-YOUR_KEY
LANGFUSE_HOST=https://traces.openautonomyx.com

# ── Langflow (workflow engine) ────────────────────────────────────────────────
LANGFLOW_SECRET_KEY=YOUR_32_CHAR_SECRET       # openssl rand -hex 32
LANGFLOW_DB_PASSWORD=YOUR_LANGFLOW_DB_PASSWORD
LANGFLOW_ADMIN_EMAIL=admin@openautonomyx.com
LANGFLOW_ADMIN_PASSWORD=YOUR_LANGFLOW_PASSWORD
LANGFLOW_VIRTUAL_KEY=sk-autonomyx-langflow-YOUR_KEY   # LiteLLM key for Langflow's spend tracking

# ── Docker Mailserver ─────────────────────────────────────────────────────────
MAIL_DOMAIN=openautonomyx.com
MAIL_PASSWORD=YOUR_MAIL_PASSWORD              # openssl rand -hex 16

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD

# ── SurrealDB Cloud (RAG + Playwright scraper) ────────────────────────────────
SURREAL_URL=https://schemadb-06ehsj292ppah8kbsk9pmnjjbc.aws-aps1.surreal.cloud
SURREAL_USER=root
SURREAL_PASS=YOUR_SURREAL_PASSWORD
SURREAL_NS=autonomyx
SURREAL_DB=scrapes

# ── Ollama tuning ─────────────────────────────────────────────────────────────
OLLAMA_MEM_LIMIT=76g                          # for 96GB VPS
OLLAMA_MAX_LOADED_MODELS=4
OLLAMA_NUM_PARALLEL=4
OLLAMA_KEEP_ALIVE=24h

# ── Google Vertex AI ──────────────────────────────────────────────────────────
# Project: thefractionalpm (your GCP project ID)
VERTEX_PROJECT=thefractionalpm
VERTEX_LOCATION=us-central1                   # Gemini models
# VERTEX_LOCATION=global                      # for Claude on Vertex
# VERTEX_LOCATION=us-east5                    # for Llama on Vertex MaaS

# Service account JSON key — mount into LiteLLM container
# 1. Create service account: GCP Console → IAM → Service Accounts
# 2. Grant role: Vertex AI User
# 3. Create JSON key → download
# 4. Place at ./vertex_key.json (gitignored)
# 5. Mount into container via docker-compose volume (see below)
GOOGLE_APPLICATION_CREDENTIALS=/app/vertex_key.json

# Add to docker-compose.yml litellm service volumes:
#   volumes:
#     - ./vertex_key.json:/app/vertex_key.json:ro

# ── GlitchTip (error tracking) ────────────────────────────────────────────
GLITCHTIP_SECRET_KEY=YOUR_GLITCHTIP_SECRET_KEY        # openssl rand -hex 32
GLITCHTIP_DB_PASSWORD=YOUR_GLITCHTIP_DB_PASSWORD      # openssl rand -hex 16

# ── OpenFGA (relationship-based authorization) ────────────────────────────
OPENFGA_DB_PASSWORD=YOUR_OPENFGA_DB_PASSWORD        # openssl rand -hex 16
OPENFGA_PRESHARED_KEY=YOUR_OPENFGA_PRESHARED_KEY    # openssl rand -hex 32
OPENFGA_STORE_ID=                                    # set after first deploy
OPENFGA_AUTH_MODEL_ID=                               # set after model upload
OPENFGA_URL=http://openfga:8080

# ── OPA (conditional policy engine) ──────────────────────────────────────────
OPA_URL=http://opa:8181
OPA_POLICY_PATH=/v1/data/autonomyx/gateway

# ── SurrealDB (self-hosted) ───────────────────────────────────────────────────
SURREAL_USER=root
SURREAL_PASS=YOUR_SURREAL_PASS          # openssl rand -hex 24
SURREAL_URL=http://surrealdb:8000       # internal — use this everywhere
SURREAL_URL_EXTERNAL=                   # leave blank — internal only
# Old cloud URL — keep until migration confirmed complete:
# SURREAL_URL_CLOUD=schemadb-06ehsj292ppah8kbsk9pmnjjbc.aws-aps1.surreal.cloud

# ── GlitchTip uptime monitoring ───────────────────────────────────────────────
# Create at: https://errors.openautonomyx.com/profile/auth-tokens/
GLITCHTIP_AUTH_TOKEN=
GLITCHTIP_ORG_SLUG=autonomyx
GLITCHTIP_PROJECT_SLUG=gateway

# ── OVH API (for VPS provisioning via scripts/provision_vps.py) ──────────────
# Get credentials at: https://eu.api.ovh.com/createToken/
# Required rights: GET+POST /me/sshKey, GET+POST /vps/*
# Store these as GitHub Secrets — do NOT commit here
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
OVH_VPS_NAME=vps-xxxxxxxx.vps.ovh.net
OVH_SSH_KEY_NAME=autonomyx-ci

# ── Hostinger API (for VPS provisioning via scripts/provision_vps_hostinger.py) ──
# Get token at: hPanel → Account → API → Generate token
# Store as GitHub Secret — do NOT commit here
HOSTINGER_API_TOKEN=
HOSTINGER_VM_ID=         # from hPanel URL: /vps/{VM_ID}/overview
HOSTINGER_SSH_KEY_NAME=autonomyx-ci
