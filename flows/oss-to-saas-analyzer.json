{
  "name": "Autonomyx OSS to SaaS Analyzer",
  "description": "Score any OSS GitHub project across 5 commercial service archetypes. Returns scores, recommended mix, 90-day action plan, and risks. For evaluating open-source monetisation opportunities.",
  "data": {
    "nodes": [
      {
        "id": "Input",
        "type": "genericNode",
        "data": {
          "type": "TextInput",
          "node": {
            "template": {
              "github_repo": {
                "type": "str",
                "required": true,
                "display_name": "GitHub Repo",
                "placeholder": "e.g. langfuse/langfuse or https://github.com/langfuse/langfuse",
                "value": "",
                "show": true
              },
              "target_market": {
                "type": "str",
                "required": false,
                "display_name": "Target Market",
                "placeholder": "e.g. Indian SMEs, enterprise DevOps teams",
                "value": "general",
                "show": true
              },
              "context": {
                "type": "str",
                "required": false,
                "display_name": "Your Context",
                "placeholder": "e.g. We already run a managed hosting business",
                "value": "",
                "show": true
              }
            },
            "display_name": "Input"
          }
        },
        "position": {
          "x": 80,
          "y": 300
        }
      },
      {
        "id": "Prompt",
        "type": "genericNode",
        "data": {
          "type": "Prompt",
          "node": {
            "template": {
              "template": {
                "type": "str",
                "value": "You are an OSS commercialisation expert. Score this OSS project and return ONLY valid JSON.\n\nGitHub repo: {github_repo}\nTarget market: {target_market}\nExisting SaaS context: {context}\n\nScore across 5 service archetypes and return this exact JSON:\n{{\n  \"repo\": \"{github_repo}\",\n  \"analysis_date\": \"<ISO date>\",\n  \"project_summary\": \"What this OSS project does\",\n  \"licence\": \"MIT|Apache2|GPL|AGPL|BSL|other\",\n  \"commercial_friendly\": true/false,\n  \"github_stats\": {{\"stars\": \"...\", \"forks\": \"...\", \"contributors\": \"...\", \"last_commit\": \"...\"}},\n  \"archetypes\": {{\n    \"managed_hosting\": {{\"score\": <0-100>, \"rationale\": \"...\", \"revenue_model\": \"...\", \"effort\": \"low|medium|high\", \"examples\": [\"...\"]}},\n    \"api_service\": {{\"score\": <0-100>, \"rationale\": \"...\", \"revenue_model\": \"...\", \"effort\": \"low|medium|high\"}},\n    \"consulting_implementation\": {{\"score\": <0-100>, \"rationale\": \"...\", \"revenue_model\": \"...\", \"effort\": \"low|medium|high\"}},\n    \"managed_service_ops\": {{\"score\": <0-100>, \"rationale\": \"...\", \"revenue_model\": \"...\", \"effort\": \"low|medium|high\"}},\n    \"vertical_saas\": {{\"score\": <0-100>, \"rationale\": \"...\", \"revenue_model\": \"...\", \"effort\": \"low|medium|high\"}}\n  }},\n  \"recommended_mix\": [\"top 2 archetypes to pursue\"],\n  \"verdict\": \"Strongly Recommended|Recommended|Possible|Not Recommended\",\n  \"first_90_days\": [\"concrete action 1\", \"concrete action 2\", \"concrete action 3\"],\n  \"risks\": [\"licence risk\", \"competition risk\", \"technical risk\"]\n}}\n\nReturn ONLY JSON.",
                "display_name": "Prompt",
                "show": true
              }
            },
            "display_name": "Prompt"
          }
        },
        "position": {
          "x": 380,
          "y": 300
        }
      },
      {
        "id": "LLM",
        "type": "genericNode",
        "data": {
          "type": "OpenAIModel",
          "node": {
            "template": {
              "openai_api_base": {
                "type": "str",
                "value": "http://litellm:4000/v1",
                "display_name": "API Base",
                "show": true
              },
              "openai_api_key": {
                "type": "str",
                "value": "{sk-autonomyx-langflow-prod}",
                "display_name": "API Key",
                "show": true,
                "password": true
              },
              "model_name": {
                "type": "str",
                "value": "ollama/qwen3:30b-a3b",
                "display_name": "Model",
                "show": true
              },
              "temperature": {
                "type": "float",
                "value": 0.1,
                "display_name": "Temperature",
                "show": true
              },
              "max_tokens": {
                "type": "int",
                "value": 4096,
                "display_name": "Max Tokens",
                "show": true
              },
              "json_mode": {
                "type": "bool",
                "value": true,
                "display_name": "JSON Mode",
                "show": true
              }
            },
            "display_name": "Qwen3-30B (OSS Analyst)"
          }
        },
        "position": {
          "x": 680,
          "y": 300
        }
      },
      {
        "id": "Output",
        "type": "genericNode",
        "data": {
          "type": "TextOutput",
          "node": {
            "template": {
              "input_value": {
                "type": "str",
                "required": true,
                "display_name": "OSS to SaaS Analysis",
                "show": true
              }
            },
            "display_name": "OSS to SaaS Analysis"
          }
        },
        "position": {
          "x": 980,
          "y": 300
        }
      }
    ],
    "edges": [
      {
        "id": "edge-Input-Prompt",
        "source": "Input",
        "sourceHandle": "github_repo",
        "target": "Prompt",
        "targetHandle": "github_repo"
      },
      {
        "id": "edge-Input-Prompt",
        "source": "Input",
        "sourceHandle": "target_market",
        "target": "Prompt",
        "targetHandle": "target_market"
      },
      {
        "id": "edge-Input-Prompt",
        "source": "Input",
        "sourceHandle": "context",
        "target": "Prompt",
        "targetHandle": "context"
      },
      {
        "id": "edge-Prompt-LLM",
        "source": "Prompt",
        "sourceHandle": "prompt",
        "target": "LLM",
        "targetHandle": "input_value"
      },
      {
        "id": "edge-LLM-Output",
        "source": "LLM",
        "sourceHandle": "text",
        "target": "Output",
        "targetHandle": "input_value"
      }
    ],
    "viewport": {
      "zoom": 0.8,
      "x": 0,
      "y": 0
