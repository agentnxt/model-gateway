{
  "name": "Autonomyx SaaS Evaluator",
  "description": "Multi-persona enterprise SaaS evaluation. Input: product name, evaluator role, use case. Output: scored JSON across 8 dimensions with recommendation and next steps.",
  "data": {
    "nodes": [
      {
        "id": "Input",
        "type": "genericNode",
        "data": {
          "type": "TextInput",
          "node": {
            "template": {
              "product_name": {
                "type": "str",
                "required": true,
                "display_name": "Product Name",
                "placeholder": "e.g. Notion, Jira, Salesforce",
                "value": "",
                "show": true
              },
              "persona": {
                "type": "str",
                "required": false,
                "display_name": "Evaluator Persona",
                "placeholder": "CISO / CTO / Procurement / IT Admin / Dept Head",
                "value": "CTO",
                "show": true
              },
              "use_case": {
                "type": "str",
                "required": false,
                "display_name": "Use Case",
                "placeholder": "e.g. Project management for 50-person engineering team",
                "value": "",
                "show": true
              },
              "org_size": {
                "type": "str",
                "required": false,
                "display_name": "Organisation Size",
                "placeholder": "e.g. 50-person startup / 500-person enterprise",
                "value": "50-500 employees",
                "show": true
              }
            },
            "display_name": "Input"
          }
        },
        "position": {
          "x": 80,
          "y": 300
        }
      },
      {
        "id": "Prompt",
        "type": "genericNode",
        "data": {
          "type": "Prompt",
          "node": {
            "template": {
              "template": {
                "type": "str",
                "value": "You are an enterprise SaaS evaluation expert. Evaluate the product and return ONLY valid JSON.\n\nProduct: {product_name}\nEvaluator persona: {persona}\nUse case: {use_case}\nOrganisation size: {org_size}\n\nReturn this exact JSON structure:\n{{\n  \"product\": \"{product_name}\",\n  \"persona\": \"{persona}\",\n  \"evaluation_date\": \"<ISO date>\",\n  \"overall_score\": <0-100>,\n  \"recommendation\": \"Strongly Recommend|Recommend|Evaluate Further|Do Not Recommend\",\n  \"dimensions\": {{\n    \"features\": {{\"score\": <0-100>, \"findings\": [\"...\"], \"gaps\": [\"...\"]}},\n    \"ai_ml\": {{\"score\": <0-100>, \"findings\": [\"...\"], \"gaps\": [\"...\"]}},\n    \"security_compliance\": {{\"score\": <0-100>, \"certifications\": [\"SOC2\",\"ISO27001\",\"GDPR\"], \"findings\": [\"...\"]}},\n    \"api_integrations\": {{\"score\": <0-100>, \"findings\": [\"...\"], \"gaps\": [\"...\"]}},\n    \"pricing\": {{\"score\": <0-100>, \"model\": \"...\", \"findings\": [\"...\"]}},\n    \"support_sla\": {{\"score\": <0-100>, \"findings\": [\"...\"]}},\n    \"vendor_health\": {{\"score\": <0-100>, \"funding\": \"...\", \"employees\": \"...\", \"findings\": [\"...\"]}},\n    \"user_sentiment\": {{\"score\": <0-100>, \"g2_rating\": \"...\", \"findings\": [\"...\"]}}\n  }},\n  \"strengths\": [\"...\"],\n  \"weaknesses\": [\"...\"],\n  \"alternatives\": [\"competitor1\", \"competitor2\"],\n  \"questions_for_vendor\": [\"...\"],\n  \"next_steps\": [\"...\"]\n}}\n\nBe thorough. Return ONLY JSON.",
                "display_name": "Prompt",
                "show": true
              }
            },
            "display_name": "Prompt"
          }
        },
        "position": {
          "x": 380,
          "y": 300
        }
      },
      {
        "id": "LLM",
        "type": "genericNode",
        "data": {
          "type": "OpenAIModel",
          "node": {
            "template": {
              "openai_api_base": {
                "type": "str",
                "value": "http://litellm:4000/v1",
                "display_name": "API Base",
                "show": true
              },
              "openai_api_key": {
                "type": "str",
                "value": "{sk-autonomyx-langflow-prod}",
                "display_name": "API Key",
                "show": true,
                "password": true
              },
              "model_name": {
                "type": "str",
                "value": "ollama/qwen3:30b-a3b",
                "display_name": "Model",
                "show": true
              },
              "temperature": {
                "type": "float",
                "value": 0.1,
                "display_name": "Temperature",
                "show": true
              },
              "max_tokens": {
                "type": "int",
                "value": 6144,
                "display_name": "Max Tokens",
                "show": true
              },
              "json_mode": {
                "type": "bool",
                "value": true,
                "display_name": "JSON Mode",
                "show": true
              }
            },
            "display_name": "Qwen3-30B (Evaluator)"
          }
        },
        "position": {
          "x": 680,
          "y": 300
        }
      },
      {
        "id": "Output",
        "type": "genericNode",
        "data": {
          "type": "TextOutput",
          "node": {
            "template": {
              "input_value": {
                "type": "str",
                "required": true,
                "display_name": "SaaS Evaluation",
                "show": true
              }
            },
            "display_name": "SaaS Evaluation"
          }
        },
        "position": {
          "x": 980,
          "y": 300
        }
      }
    ],
    "edges": [
      {
        "id": "edge-Input-Prompt",
        "source": "Input",
        "sourceHandle": "product_name",
        "target": "Prompt",
        "targetHandle": "product_name"
      },
      {
        "id": "edge-Input-Prompt",
