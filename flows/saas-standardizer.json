{
  "name": "Autonomyx SaaS Standardizer",
  "description": "Produce exhaustive standardised SaaS product profiles across 18 dimensions. Input: product name. Output: JSON profile covering features, pricing, security, API, integrations, funding, analyst rankings.",
  "data": {
    "nodes": [
      {
        "id": "Input",
        "type": "genericNode",
        "data": {
          "type": "TextInput",
          "node": {
            "template": {
              "product_name": {
                "type": "str",
                "required": true,
                "display_name": "Product Name",
                "placeholder": "e.g. Linear, Figma, Supabase",
                "value": "",
                "show": true
              },
              "dimensions": {
                "type": "str",
                "required": false,
                "display_name": "Dimensions",
                "placeholder": "all / pricing,security,api / custom",
                "value": "all",
                "show": true
              }
            },
            "display_name": "Input"
          }
        },
        "position": {
          "x": 80,
          "y": 300
        }
      },
      {
        "id": "Prompt",
        "type": "genericNode",
        "data": {
          "type": "Prompt",
          "node": {
            "template": {
              "template": {
                "type": "str",
                "value": "You are a SaaS research analyst. Produce an exhaustive standardised profile and return ONLY valid JSON.\n\nProduct: {product_name}\nDimensions requested: {dimensions}\n\nReturn this exact JSON structure:\n{{\n  \"product\": \"{product_name}\",\n  \"profile_date\": \"<ISO date>\",\n  \"summary\": \"2-3 sentence product summary\",\n  \"features\": [\"key feature 1\", \"key feature 2\"],\n  \"use_cases\": {{\"developer\": [\"...\"], \"manager\": [\"...\"], \"enterprise\": [\"...\"]}},\n  \"login_methods\": [\"SSO\", \"Email\", \"Google\", \"GitHub\"],\n  \"api\": {{\"available\": true/false, \"type\": \"REST|GraphQL|both\", \"docs_url\": \"...\", \"rate_limits\": \"...\"}},\n  \"integrations\": [\"Slack\", \"Zapier\", \"...\"],\n  \"pricing\": {{\"model\": \"per-seat|usage|flat|freemium\", \"free_tier\": true/false, \"starting_price\": \"...\", \"enterprise\": true/false}},\n  \"security\": {{\"soc2\": true/false, \"gdpr\": true/false, \"dpdp\": true/false, \"sso\": true/false, \"encryption_at_rest\": true/false}},\n  \"support\": {{\"channels\": [\"email\",\"chat\",\"phone\"], \"sla\": \"...\", \"enterprise_support\": true/false}},\n  \"open_source\": {{\"is_oss\": true/false, \"licence\": \"...\", \"github_url\": \"...\", \"github_stars\": \"...\"}},\n  \"funding\": {{\"stage\": \"...\", \"total_raised\": \"...\", \"investors\": [\"...\"]}},\n  \"analyst_rankings\": {{\"g2_rating\": \"...\", \"g2_reviews\": \"...\", \"gartner_peer_rating\": \"...\"}},\n  \"community_sentiment\": \"Brief summary of Reddit/HN/community opinion\",\n  \"notable_clients\": [\"...\"],\n  \"competitors\": [\"...\"]\n}}\n\nBe exhaustive. Return ONLY JSON.",
                "display_name": "Prompt",
                "show": true
              }
            },
            "display_name": "Prompt"
          }
        },
        "position": {
          "x": 380,
          "y": 300
        }
      },
      {
        "id": "LLM",
        "type": "genericNode",
        "data": {
          "type": "OpenAIModel",
          "node": {
            "template": {
              "openai_api_base": {
                "type": "str",
                "value": "http://litellm:4000/v1",
                "display_name": "API Base",
                "show": true
              },
              "openai_api_key": {
                "type": "str",
                "value": "{sk-autonomyx-langflow-prod}",
                "display_name": "API Key",
                "show": true,
                "password": true
              },
              "model_name": {
                "type": "str",
                "value": "ollama/qwen3:30b-a3b",
                "display_name": "Model",
                "show": true
              },
              "temperature": {
                "type": "float",
                "value": 0.1,
                "display_name": "Temperature",
                "show": true
              },
              "max_tokens": {
                "type": "int",
                "value": 6144,
                "display_name": "Max Tokens",
                "show": true
              },
              "json_mode": {
                "type": "bool",
                "value": true,
                "display_name": "JSON Mode",
                "show": true
              }
            },
            "display_name": "Qwen3-30B (Profiler)"
          }
        },
        "position": {
          "x": 680,
          "y": 300
        }
      },
      {
        "id": "Output",
        "type": "genericNode",
        "data": {
          "type": "TextOutput",
          "node": {
            "template": {
              "input_value": {
                "type": "str",
                "required": true,
                "display_name": "SaaS Profile",
                "show": true
              }
            },
            "display_name": "SaaS Profile"
          }
        },
        "position": {
          "x": 980,
          "y": 300
        }
      }
    ],
    "edges": [
      {
        "id": "edge-Input-Prompt",
        "source": "Input",
        "sourceHandle": "product_name",
        "target": "Prompt",
        "targetHandle": "product_name"
      },
      {
        "id": "edge-Input-Prompt",
        "source": "Input",
        "sourceHandle": "dimensions",
        "target": "Prompt",
        "targetHandle": "dimensions"
      },
      {
        "id": "edge-Prompt-LLM",
        "source": "Prompt",
        "sourceHandle": "prompt",
        "target": "LLM",
        "targetHandle": "input_value"
      },
      {
        "id": "edge-LLM-Output",
        "source": "LLM",
        "sourceHandle": "text",
        "target": "Output",
        "targetHandle": "input_value"
      }
    ],
    "viewport": {
      "zoom": 0.8,
      "x": 0,
      "y": 0
    }
  },
  "is_component": false,
  "last_tested_version": "1.0",
  "variables": [
    {
      "name": "LANGFLOW_VIRTUAL_KEY",
      "type": "str",
